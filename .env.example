AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_PROVIDER=deepseek

# Optional PostgreSQL-backed server storage.
# false = localStorage compatibility mode; true requires both DATABASE_URL and a 32+ character secret.
# If enabled storage is unhealthy, the app enters degraded mode and does not silently write locally.
DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_agent_hub
SERVER_STORAGE_ENABLED=false
STORAGE_SESSION_SECRET=replace_with_at_least_32_random_characters

# Optional proxy for server-side LLM requests. Leave empty unless your runtime needs a proxy.
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# Optional request timeout for LLM requests.
AI_REQUEST_TIMEOUT_MS=20000
