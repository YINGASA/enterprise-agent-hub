AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_PROVIDER=deepseek

# Optional proxy for server-side LLM requests, useful when Node.js cannot access the API directly.
# Example: http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# Optional request timeout for LLM requests.
AI_REQUEST_TIMEOUT_MS=20000
