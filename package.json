{
  "name": "enterprise-agent-hub",
  "version": "2.2.2",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:storage": "vitest run src/lib/storage src/lib/server-storage src/app/api/storage src/app/api/__tests__/conversationStorageRoutes.test.ts src/app/api/__tests__/opsStorageSummary.test.ts src/app/api/__tests__/agentRoute.test.ts src/app/api/__tests__/agentStreamRoute.test.ts",
    "test:storage:postgres": "vitest run src/lib/server-storage/__tests__/postgres.integration.test.ts --reporter=verbose",
    "test:migration:v221": "node scripts/test-v221-migration-upgrade.mjs",
    "test:migration:v222": "node scripts/test-v222-migration-upgrade.mjs",
    "test:knowledge-import": "vitest run src/lib/knowledge/__tests__/file-parser.test.ts src/lib/knowledge/__tests__/import-quality.test.ts src/lib/storage/__tests__/knowledgePackRepository.test.ts src/lib/storage/__tests__/knowledgeImportRepository.test.ts src/lib/server-storage/__tests__/knowledgePackRepository.test.ts src/lib/server-storage/__tests__/knowledgeImportRepository.test.ts src/app/api/storage/__tests__/knowledgePackRoutes.test.ts src/app/api/storage/__tests__/knowledgeImportRoutes.test.ts src/components/knowledge-workspace/__tests__/useKnowledgeImportWorkspace.test.ts",
    "test:import:hardening": "vitest run src/lib/knowledge/__tests__/file-parser.test.ts src/lib/knowledge/__tests__/import-quality.test.ts src/lib/server-storage/__tests__/knowledgeImportConcurrency.test.ts src/lib/server-storage/__tests__/knowledgeImportRepository.test.ts src/lib/server-storage/__tests__/knowledgeRepository.test.ts src/app/api/storage/__tests__/knowledgeImportRoutes.test.ts src/components/knowledge-workspace/__tests__/useKnowledgeImportWorkspace.test.ts",
    "test:import:stress": "vitest run src/lib/knowledge/__tests__/import-stress.test.ts --reporter=verbose",
    "test:real-api:node20": "vitest run src/lib/llm/node20Compatibility.test.ts src/lib/llm/stream.test.ts src/lib/llm/sse.test.ts src/app/api/__tests__/llmHealth.test.ts src/app/api/__tests__/llmStatus.test.ts src/app/api/__tests__/agentRoute.test.ts src/app/api/__tests__/agentStreamRoute.test.ts src/lib/agent/streamProtocol.test.ts src/lib/agent/streamSafety.test.ts",
    "production:check": "node scripts/production-check.mjs",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "evaluation:mock": "vitest run src/lib/evaluation/__tests__/fullMockEvaluation.test.ts --reporter=verbose",
    "e2e": "node e2e/run.mjs",
    "audit:prod": "npm audit --omit=dev --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "mammoth": "1.12.0",
    "next": "16.2.10",
    "pdfjs-dist": "5.6.205",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "7.28.0",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "22.15.32",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/yauzl": "2.10.3",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.16",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "3.2.7"
  }
}
